					"formdata": [
						{
							"key": "file",
							"description": "The Job Description file (.txt or .pdf)",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "http://localhost:8080/jobs/upload",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"jobs",
						"upload"
					]
				},
				"description": "Uploads a JD file to the Ingestion Service via Gateway. This will trigger the Kafka event."
			},
			"response": []
		},
		{
			"name": "2. Get Analysis Status (Analyzer Service)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/analysis/status/:jobId",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"analysis",
						"status",
